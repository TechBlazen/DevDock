# DevDock - Environment Variables
# Copy this to .env and fill in your values

# Vite exposes vars prefixed with VITE_ to the browser

# AI Providers (optional - can also be set in Settings UI)
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...
VITE_OPENAI_API_KEY=sk-proj-...
VITE_GEMINI_API_KEY=AIza...

# OpenTelemetry
VITE_OTEL_ENDPOINT=http://localhost:4317
VITE_OTEL_SERVICE_NAME=devdock

# GitHub (optional - can be set in Settings UI)
VITE_GITHUB_TOKEN=ghp_...
VITE_GITHUB_ORGS=my-org,another-org

# Azure DevOps (optional - can be set in Settings UI)
VITE_ADO_ORG=my-organization
VITE_ADO_PAT=...
VITE_ADO_PROJECTS=Platform,DevOps

# OAuth Authentication (optional - can use token entry or guest mode without these)
VITE_GITHUB_OAUTH_CLIENT_ID=
VITE_MICROSOFT_OAUTH_CLIENT_ID=
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_AUTH_REDIRECT_URI=http://localhost:5173/auth/callback
